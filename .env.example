# ============================================================
# TechTrack — Environment Variables
# Copy to .env — never commit .env to git
# Ask the project leader for actual values.
# ============================================================

# ── Database SQLite ──────────────────────────────────────────
DATABASE_URL="file:./data/techtrack.db"

# ── Better Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# ── Storage (MinIO — shared VPS instance) ────────────────────
MINIO_ENDPOINT="your-minio-endpoint"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="techtrack"
MINIO_USE_SSL="true"
MINIO_FORCE_PATH_STYLE="false"

# ── Image CDN ─────────────────────────────────────────────────
NEXT_PUBLIC_IMGPROXY_URL="https://your-imgproxy-url"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Seed reproducible (opcional) ─────────────────────────────
SEED_DEFAULT_PASSWORD="change-this-demo-password"
SEED_IMAGE_SOURCE_BUCKET="mds-web"
# Seis claves separadas por coma. Cada objeto se copia una sola vez a una clave estable.
SEED_IMAGE_SOURCE_KEYS=""
