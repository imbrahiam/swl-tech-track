# ============================================================
# TechTrack MD — Environment Variables
# Copy to .env — never commit .env to git
# Ask the project leader for actual values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# VPS PostgreSQL (dev shared instance)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── Better Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Storage (MinIO — shared VPS instance) ────────────────────
MINIO_ENDPOINT="your-minio-endpoint"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="techtrack"
MINIO_USE_SSL="true"

# ── Image CDN ─────────────────────────────────────────────────
NEXT_PUBLIC_IMGPROXY_URL="https://your-imgproxy-url"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
